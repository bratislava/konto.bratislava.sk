{
  "name": "nest-tax-backend",
  "version": "0.0.5",
  "description": "Backend service for tax handling",
  "author": "Department of Innovation and Technology - City of Bratislava",
  "private": false,
  "license": "EUPL-1.2",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:migrate:prod": "prisma migrate deploy && npm run start:prod",
    "lint": "eslint \"{src,apps,libs,test}/**/*.{ts,js}\"",
    "lint:report": "eslint -f json -o eslint-report.json \"{src,apps,libs,test}/**/*.{ts,js}\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.{ts,js}\" --fix",
    "test": "jest --passWithNoTests --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "vulnerabilities": "npm audit --audit-level=high --registry=https://registry.npmjs.org"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1014.0",
    "@nestjs-cognito/auth": "^2.5.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "6.17.1",
    "@types/mssql": "^9.1.9",
    "axios": "^1.13.6",
    "bysquare": "2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "csv-parse": "^6.1.0",
    "currency.js": "^2.0.4",
    "dayjs": "^1.11.19",
    "express": "^5.2.1",
    "form-urlencoded": "^6.1.6",
    "lodash": "^4.17.23",
    "mssql": "^12.2.0",
    "nodemailer": "^8.0.1",
    "openapi-clients": "file:../openapi-clients",
    "p-limit": "3.1.0",
    "passport-headerapikey": "^1.2.2",
    "qrcode": "^1.5.4",
    "rimraf": "^6.1.2",
    "ssh2-sftp-client": "^12.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bratislava/eslint-config-nest": "^0.10.0",
    "@golevelup/ts-jest": "^3.0.0",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^5.0.6",
    "@types/jest": "30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/supertest": "^7.2.0",
    "clear": "^0.1.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "path": "^0.12.7",
    "prettier": "^3.8.1",
    "prisma": "6.17.1",
    "prisma-json-types-generator": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=24.14.x",
    "npm": ">=11.9.x"
  },
  "volta": {
    "node": "24.14.0",
    "npm": "11.9.0"
  }
}
