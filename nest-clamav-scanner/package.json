{
  "name": "nest-clamav-scanner",
  "version": "0.0.2",
  "description": "NestJS ClamAV Scanner using ClamAV.js for scanning files and streams.",
  "author": "Department of Innovation and Technology of the City of Bratislava",
  "private": false,
  "license": "LICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:migrate:prod": "prisma migrate deploy && npm run start:prod",
    "lint": "eslint \"{src,apps,libs,test}/**/*.{ts,js}\"",
    "lint:report": "eslint -f json -o eslint-report.json \"{src,apps,libs,test}/**/*.{ts,js}\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.{ts,js}\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "vulnerabilities": "npm audit --audit-level=high --registry=https://registry.npmjs.org"
  },
  "dependencies": {
    "@nestjs/common": "11.1.21",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.21",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.21",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.3",
    "@prisma/client": "6.17.1",
    "await-exec": "0.1.2",
    "axios": "1.16.0",
    "base64url": "3.0.1",
    "clamdjs": "1.0.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.4",
    "husky": "9.1.7",
    "mime-types": "3.0.2",
    "minio": "8.0.7",
    "nestjs-minio-client": "2.2.0",
    "openapi-clients": "file:../openapi-clients",
    "passport-http": "0.3.0",
    "prisma": "6.17.1",
    "rimraf": "6.0.1"
  },
  "devDependencies": {
    "@bratislava/eslint-config-nest": "0.12.0",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.21",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/mime-types": "3.0.1",
    "@types/node": "24.12.2",
    "@types/passport-http": "0.3.11",
    "eslint": "10.4.0",
    "jest": "30.4.2",
    "path": "0.12.7",
    "prettier": "3.6.2",
    "source-map-support": "0.5.21",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=24.15.x",
    "npm": ">=11.12.x"
  },
  "volta": {
    "node": "24.15.0",
    "npm": "11.12.1"
  }
}
