{
  "name": "nest-city-account",
  "version": "0.0.2",
  "description": "City account project.",
  "author": "Bratislava city inovation",
  "private": false,
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:repl": "nest start --watch --entryFile repl",
    "start:prod": "node dist/main",
    "start:migrate:prod": "prisma migrate deploy && npm run start:prod",
    "lint": "eslint \"src/**/*.{ts,js}\" \"test/**/*.{ts,js}\"",
    "lint:report": "eslint -f json -o eslint-report.json \"src/**/*.{ts,js}\" \"test/**/*.{ts,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" \"test/**/*.{ts,js}\" --fix",
    "test": "jest --passWithNoTests --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "vulnerabilities": "npm audit --audit-level=high --registry=https://registry.npmjs.org"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.990.0",
    "@golevelup/nestjs-rabbitmq": "^7.1.2",
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.7",
    "@prisma/client": "6.17.1",
    "@types/express": "^5.0.6",
    "amqplib": "^0.10.9",
    "axios": "^1.15.0",
    "cache-manager": "^7.2.8",
    "cf-turnstile": "^1.0.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "lodash": "^4.17.23",
    "luxon": "^3.7.2",
    "mailgun.js": "^13.0.0",
    "mssql": "^12.2.0",
    "openapi-clients": "file:../openapi-clients",
    "p-limit": "^3.1.0",
    "passport-custom": "^1.1.1",
    "passport-headerapikey": "^1.2.2",
    "passport-jwt": "^4.0.1",
    "pg-promise": "^12.6.1",
    "playwright": "1.59.1",
    "rodnecislo": "^1.6.0",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bratislava/eslint-config-nest": "^0.10.0",
    "@golevelup/ts-jest": "^1.2.1",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/testing": "^11.1.18",
    "@types/amqplib": "^0.10.8",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/mssql": "^9.1.9",
    "@types/node": "24.12.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prisma": "6.17.1",
    "prisma-json-types-generator": "^3.6.2",
    "rimraf": "^6.1.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/../test/singleton.ts"
    ]
  },
  "engines": {
    "node": ">=24.14.x",
    "npm": ">=11.11.x"
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.11.0"
  }
}
