{
  "name": "city-account-next",
  "version": "1.5.0",
  "private": true,
  "license": "EUPL-1.2",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "next dev | pino-pretty -c",
    "develop": "next dev | pino-pretty -c",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build",
    "build:e2e": "cp .env.e2e .env.production.local && next build",
    "start": "next start",
    "typecheck": "tsc",
    "lint": "eslint src",
    "lint:quiet": "npm run lint -- --quiet",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest --watch",
    "test:ci": "jest --ci",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "parse-translations": "i18next",
    "generate-client-strapi": "graphql-codegen && prettier --write src/clients/graphql-strapi/api.ts",
    "gen": "npm run generate-client-strapi",
    "update-react-aria": "npm install @internationalized/date@latest @react-stately/utils@latest react-aria@latest react-aria-components@latest react-stately@latest @react-aria/utils@latest --save-exact --save-exact-dev",
    "update-rjsf": "npm install @rjsf/core@latest @rjsf/utils@latest @rjsf/validator-ajv8@latest ajv@latest ajv-formats@latest --save-exact",
    "update-markdown": "npm install remark-directive@latest remark-directive-rehype@latest remark-gfm@latest remark-supersub@latest rehype-raw@latest rehype-sanitize@latest",
    "update-next": "npx @next/codemod@canary upgrade latest",
    "update-typescript": "npm install typescript@latest ts-node@latest --save-dev --save-exact",
    "update-amplify": "npm install aws-amplify@latest @aws-amplify/adapter-nextjs@latest --save-exact",
    "update-tailwind": "npm install tailwind-merge@latest clsx@latest --save-exact && npm install tailwindcss@latest @tailwindcss/postcss@latest postcss@latest prettier-plugin-tailwindcss@latest --save-dev --save-exact",
    "update-i18next": "npm install i18next@latest next-i18next@latest react-i18next@latest --save-exact",
    "update-prettier": "npm install prettier@latest --save-dev --save-exact",
    "update-eslint": "npm install eslint@latest --save-dev --save-exact",
    "update-graphql": "npm install @graphql-codegen/cli@latest @graphql-codegen/client-preset@latest @graphql-codegen/typescript-graphql-request@latest --save-dev --save-exact && npm install graphql@latest graphql-request@latest graphql-tag@latest --save-exact"
  },
  "overrides": {
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "1.7.2",
    "@bratislava/component-library": "1.1.1",
    "@grafana/faro-core": "^2.3.1",
    "@grafana/faro-web-sdk": "^2.3.1",
    "@hookform/resolvers": "^5.2.2",
    "@iframe-resizer/child": "^5.5.9",
    "@iframe-resizer/react": "^5.5.9",
    "@internationalized/date": "3.12.0",
    "@jest/globals": "^30.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@next/third-parties": "16.2.3",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@react-aria/utils": "3.33.1",
    "@react-stately/utils": "3.11.0",
    "@rjsf/core": "6.4.2",
    "@rjsf/utils": "6.4.2",
    "@rjsf/validator-ajv8": "6.4.2",
    "@sindresorhus/slugify": "^3.0.0",
    "@tanstack/react-query": "^5.99.0",
    "@types/uuid": "^11.0.0",
    "ajv": "8.18.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "3.0.1",
    "aws-amplify": "6.16.3",
    "axios": "^1.15.0",
    "axios-retry": "^4.5.0",
    "clsx": "2.1.1",
    "focus-trap-react": "^12.0.0",
    "forms-shared": "file:../forms-shared",
    "graphql": "16.13.2",
    "graphql-request": "7.4.0",
    "graphql-tag": "2.12.6",
    "i18next": "26.0.4",
    "lodash": "^4.18.1",
    "memoize-one": "^6.0.0",
    "mime-types": "^3.0.2",
    "next": "16.2.3",
    "next-i18next": "16.0.5",
    "next-plausible": "3.12.5",
    "nuqs": "2.8.9",
    "object-hash": "^3.0.0",
    "openapi-clients": "file:../openapi-clients",
    "patch-package": "8.0.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.3",
    "pretty-bytes": "^7.1.0",
    "qs": "^6.15.1",
    "react": "19.2.5",
    "react-aria": "3.47.0",
    "react-aria-components": "1.16.0",
    "react-beforeunload": "^2.7.0",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.72.1",
    "react-i18next": "17.0.2",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^10.1.0",
    "react-resize-detector": "^12.3.0",
    "react-select": "5.10.2",
    "react-stately": "3.45.0",
    "react-turnstile": "^1.1.5",
    "react-usestateref": "^2.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-directive-rehype": "^1.0.0",
    "remark-gfm": "^4.0.1",
    "remark-supersub": "^1.0.0",
    "rooks": "9.8.0",
    "slugify": "^1.6.9",
    "tailwind-merge": "3.5.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "usehooks-ts": "3.1.1",
    "uuid": "^13.0.0",
    "yet-another-react-lightbox": "^3.31.0"
  },
  "devDependencies": {
    "@bratislava/eslint-config-next": "0.10.0",
    "@graphql-codegen/cli": "6.3.0",
    "@graphql-codegen/client-preset": "5.3.0",
    "@graphql-codegen/typescript-graphql-request": "7.0.0",
    "@next/bundle-analyzer": "16.2.3",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "4.17.24",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.12.2",
    "@types/object-hash": "^3.0.6",
    "@types/qs": "^6.15.0",
    "@types/react": "19.2.14",
    "@types/react-beforeunload": "^2.1.5",
    "@types/react-dom": "19.2.3",
    "app-root-dir": "^1.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "i18next-parser": "^9.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "8.5.9",
    "pre-commit": "^1.2.2",
    "prettier": "3.8.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=20.19.x",
    "npm": ">=10.9.x"
  },
  "volta": {
    "node": "20.19.6",
    "npm": "10.9.3"
  }
}
