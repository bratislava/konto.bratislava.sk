    "update-rjsf": "npm install @rjsf/core@latest @rjsf/utils@latest @rjsf/validator-ajv8@latest ajv@latest ajv-formats@latest -E",
    "update-tailwind": "npm install tailwindcss@latest @tailwindcss/postcss@latest postcss@latest -D -E",
    "update-react-aria": "npm install @internationalized/date@latest -E",
    "generate-assets": "ts-node scripts/assets/generate.ts",
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "build:watch": "tsc --project tsconfig.build.json --watch",
    "sandbox": "ts-node scripts/sandbox.ts",
    "create-ai-prompt": "ts-node scripts/createAiPrompt.ts",
    "save-example-forms": "ts-node scripts/saveExampleForms.ts"
  },
  "exports": {
    "./*": "./dist/*.js",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
