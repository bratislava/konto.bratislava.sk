{
  "name": "openapi-clients",
  "version": "1.0.0",
  "private": false,
  "license": "EUPL-1.2",
  "bin": {
    "openapi-clients": "./dist/generate-nest/cli.js"
  },
  "exports": {
    "./city-account": "./dist/city-account/index.js",
    "./forms": "./dist/forms/index.js",
    "./tax": "./dist/tax/index.js",
    "./clamav-scanner": "./dist/clamav-scanner/index.js",
    "./slovensko-sk": "./dist/slovensko-sk/index.js",
    "./magproxy": "./dist/magproxy/index.js",
    "./magproxy/base": "./dist/magproxy/base.js",
    "./generate-nest": "./dist/generate-nest/generate-nest.js",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "city-account": [
        "dist/city-account/index.d.ts"
      ],
      "forms": [
        "dist/forms/index.d.ts"
      ],
      "tax": [
        "dist/tax/index.d.ts"
      ],
      "clamav-scanner": [
        "dist/clamav-scanner/index.d.ts"
      ],
      "slovensko-sk": [
        "dist/slovensko-sk/index.d.ts"
      ],
      "magproxy": [
        "dist/magproxy/index.d.ts"
      ],
      "magproxy/base": [
        "dist/magproxy/base.d.ts"
      ],
      "generate-nest": [
        "dist/generate-nest/generate-nest.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "prettier": "prettier --write ."
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "2.32.0",
    "@nestjs/swagger": "11.2.6",
    "@types/app-root-dir": "0.1.4",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.12.2",
    "app-root-dir": "1.0.2",
    "axios": "1.16.0",
    "camelcase": "9.0.0",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "diff": "9.0.0",
    "fs-extra": "11.3.4",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@nestjs/swagger": "^11.0.0",
    "axios": "1.16.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.15.x",
    "npm": ">=11.12.x"
  },
  "volta": {
    "node": "24.15.0",
    "npm": "11.12.1"
  }
}
