{
  "name": "city-account-next",
  "version": "1.5.0",
  "private": true,
  "license": "EUPL-1.2",
  "scripts": {
    "dev": "next dev --turbopack | pino-pretty -c",
    "develop": "next dev | pino-pretty -c",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build",
    "build:e2e": "cp .env.e2e .env.production.local && next build",
    "start": "next start",
    "typecheck": "tsc",
    "lint": "eslint src",
    "lint:quiet": "npm run lint -- --quiet",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest --watch",
    "test:ci": "jest --ci",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "parse-translations": "i18next",
    "generate-client-strapi": "graphql-codegen && prettier --write src/clients/graphql-strapi/api.ts",
    "update-react-aria": "npm install @internationalized/date@latest @react-stately/utils@latest react-aria@latest react-aria-components@latest react-stately@latest @react-aria/utils@latest --save-exact --save-exact-dev",
    "update-rjsf": "npm install @rjsf/core@latest @rjsf/utils@latest @rjsf/validator-ajv8@latest ajv@latest ajv-formats@latest --save-exact",
    "update-markdown": "npm install remark-directive@latest remark-directive-rehype@latest remark-gfm@latest remark-supersub@latest rehype-raw@latest rehype-sanitize@latest",
    "update-next": "npx @next/codemod@canary upgrade latest",
    "update-typescript": "npm install typescript@latest ts-node@latest --save-dev --save-exact",
    "update-amplify": "npm install aws-amplify@latest @aws-amplify/adapter-nextjs@latest --save-exact",
    "update-tailwind": "npm install tailwind-merge@latest clsx@latest --save-exact && npm install tailwindcss@latest @tailwindcss/postcss@latest postcss@latest prettier-plugin-tailwindcss@latest --save-dev --save-exact",
    "update-i18next": "npm install i18next@latest next-i18next@latest react-i18next@latest --save-exact",
    "update-prettier": "npm install prettier@latest --save-dev --save-exact",
    "update-eslint": "npm install eslint@latest --save-dev --save-exact",
    "update-graphql": "npm install @graphql-codegen/cli@latest @graphql-codegen/client-preset@latest @graphql-codegen/typescript-graphql-request@latest --save-dev --save-exact && npm install graphql@latest graphql-request@latest graphql-tag@latest --save-exact",
    "postinstall": "patch-package"
  },
  "overrides": {
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.7"
  },
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "1.6.8",
    "@grafana/faro-core": "^1.19.0",
    "@grafana/faro-web-sdk": "^1.19.0",
    "@hookform/resolvers": "^2.9.10",
    "@iframe-resizer/child": "^5.3.2",
    "@iframe-resizer/react": "^5.3.2",
    "@internationalized/date": "3.8.2",
    "@jest/globals": "^30.0.5",
    "@monaco-editor/react": "^4.7.0",
    "@next/third-parties": "15.4.6",
    "@radix-ui/react-dropdown-menu": "2.1.15",
    "@radix-ui/react-navigation-menu": "1.2.13",
    "@react-aria/utils": "3.30.0",
    "@react-stately/utils": "3.10.8",
    "@rjsf/core": "5.24.9",
    "@rjsf/utils": "5.24.9",
    "@rjsf/validator-ajv8": "5.24.9",
    "@tanstack/react-query": "^5.85.0",
    "@types/uuid": "^10.0.0",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "aws-amplify": "6.15.5",
    "axios": "^1.13.5",
    "axios-retry": "^4.5.0",
    "clsx": "2.1.1",
    "copy-webpack-plugin": "^13.0.1",
    "focus-trap-react": "^11.0.4",
    "forms-shared": "file:../forms-shared",
    "graphql": "16.11.0",
    "graphql-request": "7.2.0",
    "graphql-tag": "2.12.6",
    "i18next": "25.3.4",
    "lodash": "^4.17.21",
    "memoize-one": "^6.0.0",
    "mime-types": "^3.0.1",
    "next": "15.4.6",
    "next-i18next": "15.4.2",
    "next-plausible": "^3.12.4",
    "nuqs": "2.4.3",
    "object-hash": "^3.0.0",
    "openapi-clients": "file:../openapi-clients",
    "patch-package": "^8.0.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "pretty-bytes": "^7.0.1",
    "qs": "^6.14.0",
    "react": "19.1.1",
    "react-aria": "3.42.0",
    "react-aria-components": "1.11.0",
    "react-beforeunload": "^2.6.0",
    "react-dom": "19.1.1",
    "react-hook-form": "^7.62.0",
    "react-i18next": "15.6.1",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^10.1.0",
    "react-resize-detector": "^12.1.0",
    "react-select": "5.10.2",
    "react-simple-snackbar": "^1.1.11",
    "react-stately": "3.40.0",
    "react-turnstile": "^1.1.4",
    "react-usestateref": "^1.0.9",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-directive-rehype": "^0.4.2",
    "remark-gfm": "^4.0.1",
    "remark-supersub": "^1.0.0",
    "rooks": "8.4.0",
    "slugify": "^1.6.6",
    "tailwind-merge": "3.3.1",
    "tailwind-scrollbar-hide": "^4.0.0",
    "usehooks-ts": "3.1.1",
    "uuid": "^11.1.0",
    "yet-another-react-lightbox": "^3.25.0"
  },
  "devDependencies": {
    "@bratislava/eslint-config-next": "0.8.0",
    "@graphql-codegen/cli": "5.0.7",
    "@graphql-codegen/client-preset": "4.8.3",
    "@graphql-codegen/typescript-graphql-request": "6.3.0",
    "@next/bundle-analyzer": "15.4.6",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.1.11",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "4.17.20",
    "@types/mime-types": "^3.0.1",
    "@types/node": "24.2.1",
    "@types/object-hash": "^3.0.6",
    "@types/qs": "^6.14.0",
    "@types/react": "19.1.10",
    "@types/react-beforeunload": "^2.1.5",
    "@types/react-dom": "19.1.7",
    "cross-env": "^10.0.0",
    "eslint": "^9.39.1",
    "i18next-parser": "^9.3.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "postcss": "8.5.6",
    "pre-commit": "^1.2.2",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "tailwindcss": "4.1.11",
    "ts-node": "10.9.2",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20.19.x",
    "npm": ">=10.9.x"
  },
  "volta": {
    "node": "20.19.6",
    "npm": "10.9.3"
  }
}
