{
  "name": "cypress",
  "scripts": {
    "lint": "eslint '**/*.ts'",
    "typecheck": "tsc",
    "start:e2e": "cd ../next && npm run build:e2e && npm run start",
    "cypress:open": "node ./run-cypress.js open --browser chrome --device all --visualTesting local",
    "cypress:open:desktop": "node ./run-cypress.js open --browser chrome --device desktop --visualTesting local",
    "cypress:open:mobile": "node ./run-cypress.js open --browser chrome --device mobile --visualTesting local",
    "cypress:run": "node ./run-cypress.js run --browser chrome --device all --visualTesting local",
    "cypress:run:desktop": "node ./run-cypress.js run --browser chrome --device desktop --visualTesting local",
    "cypress:run:mobile": "node ./run-cypress.js run --browser chrome --device mobile --visualTesting local",
    "cypress:ci": "node ./run-cypress.js run --browser chrome --device all --visualTesting ci",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check ."
  },
  "devDependencies": {
    "@frsource/cypress-plugin-visual-regression-diff": "3.3.10",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "cypress": "15.11.0",
    "cypress-file-upload": "5.0.8",
    "eslint": "8.57.0",
    "eslint-config-adjunct": "4.13.0",
    "eslint-plugin-cypress": "2.15.2",
    "eslint-plugin-prettier": "5.1.3",
    "path": "0.12.7",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "yargs": "18.0.0"
  },
  "engines": {
    "node": ">=24.15.x",
    "npm": ">=11.12.x"
  },
  "volta": {
    "node": "24.15.0",
    "npm": "11.12.1"
  }
}
